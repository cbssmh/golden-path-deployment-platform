# Copy to config/platform.env.local only to override these committed public defaults.
CLUSTER_NAME=golden-path
GITOPS_REPOSITORY_URL=https://github.com/cbssmh/golden-path-gitops.git
GITOPS_TARGET_REVISION=main
GITOPS_ROOT_PATH=applications/root
ARGOCD_NAMESPACE=argocd
GITOPS_LOCAL_PATH=../golden-path-gitops
SERVICE_A_NAMESPACE=dev
SERVICE_A_NAME=service-a
SERVICE_A_PORT=8080
